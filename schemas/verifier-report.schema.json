{
  "type": "object",
  "required": ["role", "task_id", "attempt", "commit", "verdict", "recovery_signal", "summary", "findings", "criteria_results", "proposed_tasks"],
  "properties": {
    "role": {"type": "string", "const": "verifier"},
    "task_id": {"type": "string"},
    "attempt": {"type": "integer"},
    "commit": {"type": "string"},
    "verdict": {"type": "string", "enum": ["accept", "revert"]},
    "recovery_signal": {
      "type": "string",
      "enum": ["none", "environment_blocked", "ambiguous_acceptance_criteria"]
    },
    "summary": {"type": "string"},
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "severity", "file", "recommendation"],
        "properties": {
          "description": {"type": "string"},
          "severity": {"type": "string", "enum": ["critical", "high", "medium", "low", "info"]},
          "file": {"type": "string"},
          "recommendation": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "criteria_results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["criterion", "result", "evidence"],
        "properties": {
          "criterion": {"type": "string"},
          "result": {"type": "string", "enum": ["pass", "fail", "skip"]},
          "evidence": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "proposed_tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "reason", "depends_on", "introduced_by"],
        "properties": {
          "title": {"type": "string"},
          "reason": {"type": "string"},
          "depends_on": {"type": "array", "items": {"type": "string"}},
          "introduced_by": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
